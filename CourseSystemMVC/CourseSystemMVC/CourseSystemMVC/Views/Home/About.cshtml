@{
    ViewBag.Title = "About";
}

<div class="jumbotron">
    <h1>About Course System</h1>
    <p class="lead">
        Course System is an online learning platform designed to help users learn new skills,
        take exams, track progress, and manage enrollments in a simple and structured way.
    </p>
</div>

<div class="row">

    <div class="col-md-4">
        <h2>Learn Anywhere</h2>
        <p>
            Access courses anytime and from any device. Learn at your own pace.
        </p>
    </div>

    <div class="col-md-4">
        <h2>Track Progress</h2>
        <p>
            Monitor your exam results, completed courses, and overall performance.
        </p>
    </div>

    <div class="col-md-4">
        <h2>Structured Learning</h2>
        <p>
            Courses are organized into lessons, materials, and exams for better learning experience.
        </p>
    </div>

</div>

<hr />

<h3>Platform Features</h3>

<ul>
    <li>Course enrollment system</li>
    <li>Online exams and scoring</li>
    <li>Progress tracking (passed / failed)</li>
    <li>Instructor-managed content</li>
    <li>Notifications system</li>
</ul>