@model IEnumerable<CourseSystemMVC.Models.Result>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@if (Session["RoleID"] != null && (int)Session["RoleID"] == 2)
{
    <h2>My Results</h2>
}
else if (Session["RoleID"] != null && (int)Session["RoleID"] == 1)
{
    <h2>Results</h2>
}

@if (ViewBag.AverageScore != null)
{
    <div style="margin-bottom:15px; font-size:16px; font-weight:bold;">
        📊 Your Average Score: @Math.Round((double)ViewBag.AverageScore, 2)
    </div>
}

