@{
    ViewBag.Title = "Details";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>About this course</h2>

<div>
    @*<h4>About this course</h4>*@
    <hr />
    <dl class="dl-horizontal">
        <dt>
            Course name
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Title)
        </dd>

        <dt>
            Category
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Category.Name)
        </dd>

        <dt>
            Course description
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Description)
        </dd>


        <dt>Instructor</dt>
        <dd>
            @Model.Instructor.FirstName @Model.Instructor.LastName
            <br />
            <small>
                @Model.Instructor.Bio
            </small>
        </dd>




        <dt>
            @Html.DisplayNameFor(model => model.Price)
        </dt>

        <dd>
            @Html.DisplayFor(model => model.Price)
        </dd>

    </dl>
</div>

<div class="lessons-section">

    <div style="border-top:1px solid #ddd; padding-top:10px;">
        <h3>Lessons</h3>

        @if (Model.Lessons != null && Model.Lessons.Any())
        {
            if (
                (Session["RoleID"] != null && (int)Session["RoleID"] == 1) ||
                (ViewBag.IsEnrolled != null && (bool)ViewBag.IsEnrolled)
            )
            {
                foreach (var lesson in Model.Lessons)
                {
                    <div style="margin-bottom:20px; border-bottom:1px solid #ddd; padding-bottom:10px;">

                        <strong>@lesson.Title</strong>
                        <p>@lesson.Content</p>

                        <strong>Materials:</strong>

                        @if (lesson.Materials != null && lesson.Materials.Any())
                        {
                            <ul>
                                @foreach (var m in lesson.Materials)
                                {
                                    <li>
                                        <a href="@m.FilePath" target="_blank">
                                            Open Material
                                        </a>
                                    </li>
                                }
                            </ul>

                        }
                        else
                        {
                            <p style="color:gray;">No materials</p>
                        }

                    </div>
                }
            }
            else
            {
                <div style="border-bottom:1px solid #ddd; margin-bottom:10px;">
                    <p>Please enroll to view lessons.</p>
                </div>
            }
        }
        else
        {
            <div style="border-bottom:1px solid #ddd; margin-bottom:10px;">
                <p>No lessons available.</p>
            </div>
        }
    </div>

</div>

<h3>Exams</h3>

@if (Model.Exams != null && Model.Exams.Any())
{
    if (
        (Session["RoleID"] != null && (int)Session["RoleID"] == 1) ||
        (ViewBag.IsEnrolled != null && (bool)ViewBag.IsEnrolled)
    )
    {
        foreach (var exam in Model.Exams)
        {
            <div style="display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid #ddd; padding-bottom:10px; margin-bottom:10px;">

                <strong>@exam.Title</strong>

                @if (Session["RoleID"] != null && (int)Session["RoleID"] == 1)
                {
                    <a href="/Results/Create?examId=@exam.ExamID" class="btn btn-sm btn-success">
                        Add Result
                    </a>
                }

            </div>
        }
    }
    else
    {
        <div style="border-bottom:1px solid #ddd; margin-bottom:10px;">
            <p>Please enroll to view exams.</p>
        </div>
    }
}
else
{
    <div style="border-bottom:1px solid #ddd; margin-bottom:10px;">
        <p>No exams available.</p>
    </div>
}

