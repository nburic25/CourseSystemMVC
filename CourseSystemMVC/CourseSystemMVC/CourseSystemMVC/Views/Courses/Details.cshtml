<h3>Your Results</h3>

@if (ViewBag.UserResults != null)
{
    var results = (List<CourseSystemMVC.Models.Result>)ViewBag.UserResults;

    bool hasResults = false;

    foreach (var r in results)
    {
        if (r.Exam != null && r.Exam.CourseID == Model.CourseID)
        {
            hasResults = true;

            <div style="border-bottom:1px solid #ddd; padding-bottom:10px; margin-bottom:10px;">

                <strong>@r.Exam.Title</strong>
                <br />

                Score: @r.Score

                @if (r.Score >= 50)
                {
                    <span style="color:green; margin-left:10px;">Passed</span>
                }
                else
                {
                    <span style="color:red; margin-left:10px;">Failed</span>
                }

            </div>
        }
    }

    if (!hasResults)
    {
        <p>No results available for this course.</p>
    }
}
else
{
    <p>No results available.</p>
}

<h3>Reviews</h3>

@if (Model.Reviews != null && Model.Reviews.Any())
{
    foreach (var r in Model.Reviews)
    {
        <strong>
            @r.User.FirstName @r.User.LastName
        </strong>
        <br />

        <div style="border-bottom:1px solid #ddd; margin-bottom:10px;">
            <strong>Rating: @r.Rating / 5</strong>
            <p>@r.Comment</p>

            @*@if (r.UserID == (int)Session["UserID"])
                {
                    using (Html.BeginForm("Delete", "Reviews", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", r.ReviewID)

                        <button type="submit" class="btn btn-danger btn-sm">
                            Delete
                        </button>
                    }
                }*@
        </div>
    }
}
else
{
    <p>No reviews yet.</p>
}

@if (ViewBag.IsEnrolled != null && (bool)ViewBag.IsEnrolled)
{
    <h4>Add Review</h4>

    using (Html.BeginForm("Create", "Reviews", FormMethod.Post))
    {
        @Html.AntiForgeryToken()
        @Html.Hidden("CourseID", Model.CourseID)

        <label><strong>Rating (1-5)</strong></label>
        <input type="number" name="Rating" min="1" max="5" class="form-control" />
        <br />

        <label><strong>Comment</strong></label>
        <textarea name="Comment" class="form-control"></textarea>
        <br />

        <button type="submit" class="btn btn-primary">Submit Review</button>
    }
}

<p>
    @Html.ActionLink("Back to List", "Index")

</p>

<p style="color:gray; margin-bottom:10px;">
    To enroll in this course, please complete the payment below.
</p>

<div style="display:flex; align-items:center; gap:20px; margin-bottom:10px;">

    @if (Session["RoleID"] != null && (int)Session["RoleID"] == 2)
    {
        <div style="display:flex; align-items:center; gap:10px;">

            @if (Session["UserID"] != null)
            {
                if (ViewBag.IsEnrolled != null && (bool)ViewBag.IsEnrolled)
                {
                    <span class="label label-success">Already Enrolled</span>
                }
                else
                {
                    <form method="post" action="/Payments/Create">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="CourseID" value="@Model.CourseID" />
                        <button type="submit" class="btn btn-success btn-sm">
                            Pay Now
                        </button>
                    </form>
                }
            }
            else
            {
                <span>Please login to enroll.</span>
            }

        </div>
    }

    @if (Session["RoleID"] != null && (int)Session["RoleID"] == 2)
    {
        <a href="/Enrollments/Index" class="btn btn-info btn-sm">
            Go To My Enrollments
        </a>
    }

</div>

